node_modules/
dist/
*.tsbuildinfo

# Next.js (dashboard)
.next/
next-env.d.ts

# SQLite data
packages/backend/data/
*.db
*.db-journal
*.db-wal
*.db-shm

# env
.env
.env.*

# Google Calendar OAuth credentials — secret/token, never commit.
# (data/ is already ignored above; these guard custom paths too.)
google-client-secret.json
google-token.json
**/google-client-secret.json
**/google-token.json

# Memory files hold personal content — keep local, never commit.
# Only the folder README (template/instructions) is tracked.
memory/*.md
!memory/README.md

# LINE batch runner config (real chat names — local only; chats.example.json is the tracked template).
automation/line_export/chats.json
automation/line_export/chats.test.json

# Python bytecode
automation/**/__pycache__/
automation/**/*.pyc
