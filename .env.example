# Local machine configuration template.
# Copy values you need into .env. Do not commit real .env files or secrets.

# Voice / TTS
CLAUDE_AGENT_TTS_ENABLED=1
CLAUDE_AGENT_TTS_PRESET=calm_female

# Privacy guard (Step 15)
# OFF by default. When ON, an unverified chat session gets redacted context and
# must unlock with the PIN or a secret phrase before private data is shared.
CLAUDE_AGENT_PRIVACY_GUARD_ENABLED=0
CLAUDE_AGENT_OWNER_PIN=
CLAUDE_AGENT_OWNER_SECRET_PHRASE=โอเค
# Comma-separated openers that ALSO unlock the guard (merged with the phrase
# above). Low-entropy convenience openers — NOT a secret. Case-insensitive.
CLAUDE_AGENT_OWNER_SECRET_PHRASES=โอเค,ok,ทีนี้,แล้ว,แล้วถ้า,สมมติว่า,ถ้าอย่างนั้น,ถ้าอย่างงั้น,ถ้างั้น,คือแบบนี้,แบบนี้,ฟังนะ,คือฟังนะ,เอาล่ะ

